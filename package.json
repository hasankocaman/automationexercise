{
  "name": "learnqa-dev",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "QA Learning Platform for Selenium, Playwright, Java, Python, SQL, API testing, DevOps and cloud tools",
  "scripts": {
    "dev": "vite --host",
    "dev:prod": "vite --host --mode prodtest",
    "build": "node scripts/check-seo.mjs && node scripts/check-content-integrity.mjs && node scripts/audit-interview-questions.mjs && node scripts/generate-seo-files.mjs && vite build && node scripts/generate-static-routes.mjs && node scripts/check-dist-seo.mjs",
    "content:check": "node scripts/check-content-integrity.mjs",
    "seo:check": "node scripts/check-seo.mjs",
    "seo:check-dist": "node scripts/check-dist-seo.mjs",
    "seo:files": "node scripts/generate-seo-files.mjs",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:interview-flows": "playwright test --config=playwright.interview-flows.config.ts",
    "test:quiz-audit": "playwright test --config=playwright.quiz-audit.config.ts",
    "audit:interactive": "node scripts/audit-interactive.mjs",
    "audit:interactive:missing": "node scripts/audit-interactive.mjs --missing",
    "audit:interview-questions": "node scripts/audit-interview-questions.mjs",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "node scripts/check-content-integrity.mjs",
    "post-commit": "bash scripts/post-commit-tests.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "lucide-react": "^1.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "msw": "^2.12.7",
    "postcss": "^8.4.32",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
