# LearnQA.dev — local env template. Copy to .env.local and fill in real values.
# .env.local is gitignored — never commit real Supabase keys.
#
# Bu proje İKİ ayrı Supabase projesi kullanır (2026-06-21 kararı):
#   - learnqa-test  -> premium/paywall tam aktif, sadece sen test edersin
#   - learnqa-prod  -> gerçek üyelik aktif, premium UI'ı kapalı (VITE_ENABLE_PREMIUM=false)
#
# Local geliştirme için bu projeye .env.local olarak kopyala ve
# learnqa-test proje değerlerini yaz (Project Settings > API içinde bulunur).
# GitHub Pages prod build'i bu dosyayı OKUMAZ — prod değerleri
# GitHub repo Settings > Secrets and variables > Actions içine eklenir
# ve .github/workflows/deploy.yml içinde build adımına env olarak geçirilir.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxx

# Premium/paywall UI'ını gösterir/gizler. learnqa-test'te true, learnqa-prod'da false.
VITE_ENABLE_PREMIUM=true
